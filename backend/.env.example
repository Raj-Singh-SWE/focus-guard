# To connect to Supabase PostgreSQL instead of local SQLite, 
# uncomment the line below and paste your Supabase connection string.
# 
# Make sure your string starts with "postgresql://" and includes your password.
# Example: postgresql://postgres:YOUR_PASSWORD@db.xxxxxxxx.supabase.co:5432/postgres

# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.xxx.supabase.co:5432/postgres"

